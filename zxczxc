    Title    = "🚀 Ultra FPS Booster",
    Desc     = "Maximum performance mode",
    Icon     = "zap-off",
    Callback = function()
        -- Qualidade mínima de renderização
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

        -- Lighting
        Lighting.GlobalShadows    = false
        Lighting.FogEnd           = math.huge  -- desativa névoa de forma eficaz
        Lighting.FogStart         = math.huge
        Lighting.Brightness       = 1
        Lighting.EnvironmentDiffuseScale  = 0
        Lighting.EnvironmentSpecularScale = 0

        -- Coleta antes de destruir (evita pular elementos)
        local toDestroy = collectDescendants(Workspace, function(obj)
            return obj:IsA("ParticleEmitter")
                or obj:IsA("Trail")
                or obj:IsA("Smoke")
                or obj:IsA("Fire")
                or obj:IsA("Sparkles")
                or obj:IsA("Decal")
                or obj:IsA("Texture")
                or obj:IsA("SelectionBox")
                or obj:IsA("SurfaceAppearance") -- PBR textures, muito pesadas
        end)

        for _, obj in ipairs(toDestroy) do
            if obj and obj.Parent then
                obj:Destroy()
            end
        end

        -- Reduz material e reflexo de todas as partes
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                obj.Material    = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
