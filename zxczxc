-- Função auxiliar para evitar erros ao iterar + destruir
local function collectDescendants(parent, filter)
    local result = {}
    for _, obj in pairs(parent:GetDescendants()) do
        if filter(obj) then
            table.insert(result, obj)
        end
    end
    return result
end

