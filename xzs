local resultCards={}

local function estimateLines(txt, textSize, availWidth)
	local charsPerLine = math.max(1, math.floor(availWidth / (textSize * 0.55)))
	local lines = 1
	local col = 0
	for word in txt:gmatch("%S+") do
		col = col + #word + 1
		if col > charsPerLine then lines = lines + 1; col = #word + 1 end
	end
	for _ in txt:gmatch("\n") do lines = lines + 1 end
	return lines
end

local function makeCard(icon, lbtxt, mainTxt, accent, subTxt, order)
	local LX      = 12
	local RX      = 8
	local TS_lbl  = isMobile and 8 or 11
	local TS_main = isMobile and 12 or 18
	local TS_sub  = isMobile and 8 or 11
	local LH_lbl  = isMobile and 12 or 20
	local LH_main = isMobile and 16 or 27
	local LH_sub  = isMobile and 11 or 16
	local TOP     = 6
	local BOT     = 6

	local availW  = W - 14*2 - LX - RX

	local subLines = 0
	if subTxt and subTxt ~= "" then
		subLines = estimateLines(subTxt, TS_sub, availW)
	end

	local cardH = TOP + LH_lbl + 2 + LH_main + (subLines > 0 and (2 + LH_sub * subLines) or 0) + BOT

	local card = Instance.new("Frame")
	card.Size = UDim2.new(1,0,0,cardH)
	card.BackgroundColor3 = Color3.fromRGB(16,16,20)
	card.BorderSizePixel = 0
	card.LayoutOrder = order or 1
	card.ZIndex = 12
	card.Parent = resCon
	corner(card,7); stroke(card,BORDER,1,0)

	local bar=Instance.new("Frame"); bar.Size=UDim2.new(0,3,1,0)
	bar.BackgroundColor3=accent; bar.BorderSizePixel=0; bar.ZIndex=13; bar.Parent=card; corner(bar,2)

	local y = TOP
	lbl(card, icon.."  "..lbtxt, DIMGRAY, Enum.Font.GothamMedium, TS_lbl,
		UDim2.new(1,-(LX+RX),0,LH_lbl), UDim2.new(0,LX,0,y), 13)
	y = y + LH_lbl + 2

	lbl(card, mainTxt, accent, Enum.Font.GothamBold, TS_main,
		UDim2.new(1,-(LX+RX),0,LH_main), UDim2.new(0,LX,0,y), 13)
	y = y + LH_main + 2

	if subTxt and subTxt ~= "" then
		lbl(card, subTxt, GRAY, Enum.Font.Gotham, TS_sub,
			UDim2.new(1,-(LX+RX),0,LH_sub*subLines), UDim2.new(0,LX,0,y), 13)
	end

	table.insert(resultCards,card); return card
end

local function makePreXP(amount, order)
	local LX      = 12
	local RX      = 8
	local TS_ttl  = isMobile and 9 or 13
	local TS_sub  = isMobile and 8 or 11
	local LH_ttl  = isMobile and 13 or 22
	local LH_sub  = isMobile and 11 or 16
	local TOP     = 6
	local BOT     = 6

	local availW  = W - 14*2 - LX - RX
	local subTxt  = "Add +"..amount.." EXP ao pet ANTES de glitchar\n(use esteira ou outra rock)"
	local subLines= estimateLines(subTxt, TS_sub, availW)
	local cardH   = TOP + LH_ttl + 3 + LH_sub*subLines + BOT

	local card=Instance.new("Frame")
	card.Size=UDim2.new(1,0,0,cardH); card.BackgroundColor3=Color3.fromRGB(34,24,7)
	card.BorderSizePixel=0; card.LayoutOrder=order or 1; card.ZIndex=12; card.Parent=resCon
	corner(card,7); stroke(card,AMBER,1.5,0.3)

	local bar=Instance.new("Frame"); bar.Size=UDim2.new(0,3,1,0)
	bar.BackgroundColor3=AMBER; bar.BorderSizePixel=0; bar.ZIndex=13; bar.Parent=card; corner(bar,2)

	local y = TOP
	lbl(card,"⚠️  PRE-LOAD REQUIRED",AMBER,Enum.Font.GothamBold,TS_ttl,
		UDim2.new(1,-(LX+RX),0,LH_ttl),UDim2.new(0,LX,0,y),13)
	y = y + LH_ttl + 3

	lbl(card, subTxt, Color3.fromRGB(185,145,65), Enum.Font.Gotham, TS_sub,
		UDim2.new(1,-(LX+RX),0,LH_sub*subLines), UDim2.new(0,LX,0,y), 13)

	table.insert(resultCards,card); return card
end

