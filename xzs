local function getNextGlitches(reb, rockName, count)
	local list = glitchLists[rockName]
	if not list then return {} end
	local out = {}
	for _, e in ipairs(list) do
		if e[1] > reb then
			table.insert(out, {reb=e[1], stats=e[2], preXP=e[3]})
			if #out >= (count or 3) then break end
		end
	end
	return out
end

